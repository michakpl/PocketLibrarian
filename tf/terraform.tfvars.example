# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit real secrets.

environment = "dev"
location    = "westeurope"

# Must be unique within your Azure subscription (max 8 chars, lowercase alphanumeric).
# Used to form globally unique names for: Storage Account, ACR, Key Vault, Redis.
name_prefix = "pcktlib"

# ── SQL ──────────────────────────────────────────────────────────────────────
sql_admin_login    = "sqladmin"
sql_admin_password = "REPLACE_ME_STRONG_PASSWORD_Abc123!"

# ── Microsoft Entra ID ──x──────────────────────────────────────────────────────
# App registration client IDs from the Azure portal
api_entraid_client_id = "REPLACE_ME_API_CLIENT_ID"
web_entraid_client_id = "REPLACE_ME_WEB_CLIENT_ID"

# Client secret from the API app registration (Certificates & secrets)
api_entraid_client_secret = "REPLACE_ME_WEB_CLIENT_SECRET"

# Audience for the API app registration
api_entraid_audience = "REPLACE_ME_API_AUDIENCE"

# Scope for the Web app registration (exposed by the API app registration → API permissions)
web_entraid_scope_base = "REPLACE_ME_WEB_SCOPE_BASE"

# ── External APIs & Auth ──────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials
google_books_api_key = "REPLACE_ME_GOOGLE_BOOKS_KEY"

# Generate with: openssl rand -base64 32
web_session_secret = "REPLACE_ME_NEXTAUTH_SECRET_BASE64"
